# Copy this file to .env and fill in real values. Never commit .env itself.

# Groq (get a free key at https://console.groq.com/keys)
GROQ_API_KEY=my_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Where uploaded documents and the vector store live on disk (Phase 1)
UPLOAD_DIR=./storage/uploads
CHROMA_DIR=./storage/chroma

# Chunking settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# CORS - your frontend's URL(s), comma separated
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# Added in Phase 2 (auth + database) - not used yet, but reserve the names
DATABASE_URL=postgresql://user:password@localhost:5432/nexagent
JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440